---
import "../styles/global.css";
import { SITE } from "../config/site";

interface Props {
  title: string;
  description?: string;
  /** Absolute URL to OG image, defaults to /og-default.png */
  ogImage?: string;
  /** Set to true on blog post pages to show article schema */
  article?: boolean;
}

const {
  title,
  description = SITE.description,
  ogImage = "/og-default.png",
  article = false,
} = Astro.props;

const absoluteOgImage = new URL(ogImage, Astro.site).toString();
const currentPath = Astro.url.pathname;
const canonicalURL = new URL(currentPath, Astro.site);
const siteTitle = SITE.title;
const logoMark = `${SITE.firstName[0] ?? ""}${SITE.lastName[0] ?? ""}`.toUpperCase();
---

<!doctype html>
<html lang="en" data-theme="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="canonical" href={canonicalURL} />
    <meta name="generator" content={Astro.generator} />

    <!-- Primary -->
    <title>{title === siteTitle ? title : `${title} · ${siteTitle}`}</title>
    <meta name="description" content={description} />

    <!-- Open Graph -->
    <meta property="og:type"        content={article ? "article" : "website"} />
    <meta property="og:url"         content={canonicalURL} />
    <meta property="og:title"       content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={absoluteOgImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:type" content="image/png" />

    <!-- Twitter -->
    <meta name="twitter:card"        content="summary_large_image" />
    <meta name="twitter:title"       content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image"       content={absoluteOgImage} />

    <!-- RSS autodiscovery -->
    <link rel="alternate" type="application/rss+xml" title={siteTitle} href="/rss.xml" />

    <!-- Theme init: runs before paint to avoid flash -->
    <script is:inline>
      (function () {
        const stored = localStorage.getItem("theme");
        const prefersDark = window.matchMedia("(prefers-color-scheme: dark)").matches;
        const theme = stored ?? (prefersDark ? "dark" : "light");
        document.documentElement.setAttribute("data-theme", theme);
      })();
    </script>
  </head>

  <body>
    <!-- ─── Navigation ─────────────────────────────────────────────────────── -->
    <header id="site-header">
      <nav class="container nav-inner">
        <a href="/" class="nav-logo" aria-label="Home">
          <span class="logo-mark">
            <img
              src="/images/logo-mark.gif"
              alt={logoMark}
              class="logo-mark-image"
              onerror="this.style.display='none'"
              onload="this.nextElementSibling.style.display='none'"
            />
            <span class="logo-mark-fallback">{logoMark}</span>
          </span>
        </a>

        <ul class="nav-links" role="list">
          {currentPath !== "/" && <li><a href="/">Home</a></li>}
          {!currentPath.startsWith("/projects") && <li><a href="/projects">Projects</a></li>}
          {!currentPath.startsWith("/blog") && <li><a href="/blog">Blog</a></li>}
          {!currentPath.startsWith("/certificates") && <li><a href="/certificates">Certs</a></li>}
          <li><a href="/#contact">Contact</a></li>
        </ul>

        <div class="nav-actions">
          <button
            id="theme-toggle"
            aria-label="Toggle colour theme"
            title="Toggle theme"
          >
            <!-- Sun icon (shown in dark mode) -->
            <svg class="icon-sun" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <circle cx="12" cy="12" r="4"/>
              <path d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M6.34 17.66l-1.41 1.41M19.07 4.93l-1.41 1.41"/>
            </svg>
            <!-- Moon icon (shown in light mode) -->
            <svg class="icon-moon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>
            </svg>
          </button>

          <button id="nav-toggle" class="nav-toggle" aria-label="Toggle navigation menu" aria-expanded="false">
            <span></span>
            <span></span>
            <span></span>
          </button>
        </div>
      </nav>
    </header>

    <!-- ─── Main content ────────────────────────────────────────────────────── -->
    <main id="main-content">
      <slot />
    </main>

    <!-- ─── Footer ─────────────────────────────────────────────────────────── -->
    <footer>
      <div class="container footer-inner">
        <p class="footer-copy">
          © {new Date().getFullYear()} {SITE.fullName}
          <span class="sep" aria-hidden="true">·</span>
          Built with <span aria-label="love">❤️</span> using <a href="https://astro.build" target="_blank" rel="noopener">Astro</a>
        </p>
        <ul class="footer-links" role="list">
          {SITE.social.github && <li><a href={SITE.social.github} target="_blank" rel="noopener" aria-label="GitHub">GitHub</a></li>}
          {SITE.social.linkedin && <li><a href={SITE.social.linkedin} target="_blank" rel="noopener" aria-label="LinkedIn">LinkedIn</a></li>}
          <li><a href="/rss.xml" target="_blank" rel="noopener noreferrer" aria-label="RSS feed">RSS</a></li>
          <li><a href="/sitemap.xml" target="_blank" rel="noopener noreferrer" aria-label="Sitemap">Sitemap</a></li>
        </ul>
      </div>
    </footer>

    <!-- ─── Theme toggle script ─────────────────────────────────────────────── -->
    <script>
      const btn = document.getElementById("theme-toggle");
      btn?.addEventListener("click", () => {
        const html = document.documentElement;
        const next = html.getAttribute("data-theme") === "dark" ? "light" : "dark";
        html.setAttribute("data-theme", next);
        localStorage.setItem("theme", next);
      });

      // Shrink nav on scroll
      const header = document.getElementById("site-header");
      const observer = new IntersectionObserver(
        ([e]) => header?.classList.toggle("scrolled", !e.isIntersecting),
        { rootMargin: "-1px 0px 0px 0px", threshold: [1] }
      );
      const sentinel = document.createElement("div");
      sentinel.style.cssText = "height:1px;position:absolute;top:0;width:100%;pointer-events:none";
      document.body.prepend(sentinel);
      observer.observe(sentinel);

      // Mobile nav toggle
      const navToggle = document.getElementById("nav-toggle");
      const navInner = document.querySelector(".nav-inner");
      navToggle?.addEventListener("click", () => {
        if (!navInner) return;
        const isOpen = navInner.classList.toggle("nav-open");
        navToggle.setAttribute("aria-expanded", String(isOpen));
      });
    </script>
  </body>
</html>

<style>
  /* ─── Header ─────────────────────────────────────────────────────────────── */
  #site-header {
    position: sticky;
    top: 0;
    z-index: 50;
    background: transparent;
    transition: background var(--duration) var(--ease-out),
                box-shadow var(--duration) var(--ease-out);
  }
  #site-header.scrolled {
    background: color-mix(in srgb, var(--bg) 85%, transparent);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    box-shadow: 0 1px 0 var(--border);
  }

  .nav-inner {
    position: relative;
    display: flex;
    align-items: center;
    gap: var(--space-6);
    height: 64px;
  }

  .nav-logo { flex-shrink: 0; }
  .logo-mark {
    position: relative;
    display: grid;
    place-items: center;
    width: 36px;
    height: 36px;
    border: 1.5px solid var(--border);
    border-radius: var(--radius-sm);
    transition: border-color var(--duration), color var(--duration);
  }
  .logo-mark-image {
    width: 100%;
    height: 100%;
    object-fit: contain;
    display: block;
  }
  .logo-mark-fallback {
    position: absolute;
    inset: 0;
    display: grid;
    place-items: center;
    font-family: var(--font-mono);
    font-size: 0.75rem;
    font-weight: 500;
    color: var(--text-muted);
  }
  .nav-logo:hover .logo-mark {
    border-color: var(--accent);
  }

  .nav-links {
    display: flex;
    align-items: center;
    gap: var(--space-8);
    list-style: none;
    margin-left: auto;
  }
  .nav-links a {
    font-size: 0.875rem;
    color: var(--text-muted);
    transition: color var(--duration);
    letter-spacing: 0.01em;
  }
  .nav-links a:hover { color: var(--text); }

  .nav-actions {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    margin-left: var(--space-4);
  }

  .nav-toggle {
    display: none;
    width: 36px;
    height: 36px;
    border-radius: var(--radius-sm);
    background: transparent;
    border: 1.5px solid var(--border);
    color: var(--text-muted);
    cursor: pointer;
    padding: 0.45em;
    transition: border-color var(--duration), color var(--duration), background var(--duration);
  }
  .nav-toggle:hover {
    border-color: var(--accent);
    color: var(--text);
    background: var(--bg-card);
  }
  .nav-toggle span {
    display: block;
    width: 100%;
    height: 2px;
    background: currentColor;
    margin-bottom: 4px;
    transition: transform var(--duration), opacity var(--duration);
  }
  .nav-toggle span:last-child { margin-bottom: 0; }

  .nav-inner.nav-open .nav-toggle span:nth-child(1) {
    transform: translateY(6px) rotate(45deg);
  }
  .nav-inner.nav-open .nav-toggle span:nth-child(2) {
    opacity: 0;
  }
  .nav-inner.nav-open .nav-toggle span:nth-child(3) {
    transform: translateY(-6px) rotate(-45deg);
  }

  /* Theme toggle */
  #theme-toggle {
    display: grid;
    place-items: center;
    width: 36px;
    height: 36px;
    border-radius: var(--radius-sm);
    color: var(--text-muted);
    transition: color var(--duration), background var(--duration);
  }
  #theme-toggle:hover {
    color: var(--text);
    background: var(--bg-card);
  }
  /* Show correct icon per theme */
  :root[data-theme="dark"]  #theme-toggle .icon-moon { display: none; }
  :root[data-theme="light"] #theme-toggle .icon-sun  { display: none; }

  /* Résumé button */
  .btn-resume {
    font-size: 0.8125rem;
    font-weight: 500;
    padding: 0.4em 1em;
    border: 1.5px solid var(--border);
    border-radius: var(--radius-sm);
    color: var(--text-muted);
    transition: border-color var(--duration), color var(--duration),
                background var(--duration);
    white-space: nowrap;
  }
  .btn-resume:hover {
    border-color: var(--accent);
    color: var(--accent);
    background: var(--accent-muted);
  }

  /* ─── Footer ─────────────────────────────────────────────────────────────── */
  footer {
    border-top: 1px solid var(--border);
    margin-top: var(--space-24);
  }
  .footer-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding-block: var(--space-8);
    flex-wrap: wrap;
    gap: var(--space-4);
  }
  .footer-copy {
    font-size: 0.8125rem;
    color: var(--text-muted);
  }
  .footer-copy a {
    color: var(--text-muted);
    text-underline-offset: 3px;
    text-decoration: underline;
    text-decoration-color: var(--border);
    transition: color var(--duration);
  }
  .footer-copy a:hover { color: var(--text); }
  .sep { margin-inline: var(--space-2); }
  .footer-links {
    display: flex;
    gap: var(--space-6);
    list-style: none;
  }
  .footer-links a {
    font-size: 0.8125rem;
    color: var(--text-muted);
    transition: color var(--duration);
  }
  .footer-links a:hover { color: var(--text); }

  /* ─── Responsive ─────────────────────────────────────────────────────────── */
  @media (max-width: 640px) {
    .nav-inner {
      padding-right: 4.5rem;
    }
    .nav-links {
      display: none;
      position: absolute;
      top: 100%;
      right: 0;
      width: min(100%, 18rem);
      flex-direction: column;
      gap: 0;
      list-style: none;
      background: var(--bg);
      border: 1px solid var(--border);
      border-radius: var(--radius-md);
      box-shadow: 0 20px 50px rgba(0, 0, 0, 0.25);
      overflow: hidden;
      z-index: 60;
    }
    .nav-inner.nav-open .nav-links {
      display: flex;
    }
    .nav-links li {
      border-bottom: 1px solid var(--border);
    }
    .nav-links li:last-child {
      border-bottom: none;
    }
    .nav-links a {
      padding: 0.9rem 1rem;
      display: block;
      font-size: 0.95rem;
      color: var(--text);
      background: var(--bg);
    }
    .nav-actions {
      gap: var(--space-2);
      margin-left: 0;
    }
    .nav-toggle {
      display: inline-grid;
      position: absolute;
      top: 0.85rem;
      right: 0.85rem;
    }
    .btn-resume {
      display: none;
    }
  }
</style>
