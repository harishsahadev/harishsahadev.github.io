---
import "../styles/global.css";
import { SITE } from "../config/site";

interface Props {
  title: string;
  description?: string;
  /** Absolute URL to OG image, defaults to /og-default.png */
  ogImage?: string;
  /** Set to true on blog post pages to show article schema */
  article?: boolean;
}

const {
  title,
  description = SITE.description,
  ogImage = "/og-default.png",
  article = false,
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const siteTitle = SITE.title;
const logoMark = `${SITE.firstName[0] ?? ""}${SITE.lastName[0] ?? ""}`.toUpperCase();
---

<!doctype html>
<html lang="en" data-theme="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="canonical" href={canonicalURL} />
    <meta name="generator" content={Astro.generator} />

    <!-- Primary -->
    <title>{title === siteTitle ? title : `${title} · ${siteTitle}`}</title>
    <meta name="description" content={description} />

    <!-- Open Graph -->
    <meta property="og:type"        content={article ? "article" : "website"} />
    <meta property="og:url"         content={canonicalURL} />
    <meta property="og:title"       content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image"       content={ogImage} />

    <!-- Twitter -->
    <meta name="twitter:card"        content="summary_large_image" />
    <meta name="twitter:title"       content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image"       content={ogImage} />

    <!-- RSS autodiscovery -->
    <link rel="alternate" type="application/rss+xml" title={siteTitle} href="/rss.xml" />

    <!-- Theme init: runs before paint to avoid flash -->
    <script is:inline>
      (function () {
        const stored = localStorage.getItem("theme");
        const prefersDark = window.matchMedia("(prefers-color-scheme: dark)").matches;
        const theme = stored ?? (prefersDark ? "dark" : "light");
        document.documentElement.setAttribute("data-theme", theme);
      })();
    </script>
  </head>

  <body>
    <!-- ─── Navigation ─────────────────────────────────────────────────────── -->
    <header id="site-header">
      <nav class="container nav-inner">
        <a href="/" class="nav-logo" aria-label="Home">
          <span class="logo-mark">{logoMark}</span>
        </a>

        <ul class="nav-links" role="list">
          <li><a href="/projects">Projects</a></li>
          <li><a href="/blog">Blog</a></li>
          <li><a href="/#certifications">Certs</a></li>
          <li><a href="/#contact">Contact</a></li>
        </ul>

        <div class="nav-actions">
          <button
            id="theme-toggle"
            aria-label="Toggle colour theme"
            title="Toggle theme"
          >
            <!-- Sun icon (shown in dark mode) -->
            <svg class="icon-sun" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <circle cx="12" cy="12" r="4"/>
              <path d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M6.34 17.66l-1.41 1.41M19.07 4.93l-1.41 1.41"/>
            </svg>
            <!-- Moon icon (shown in light mode) -->
            <svg class="icon-moon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>
            </svg>
          </button>

          <a href={SITE.resumeUrl} class="btn-resume" target="_blank" rel="noopener">
            Résumé
          </a>
        </div>
      </nav>
    </header>

    <!-- ─── Main content ────────────────────────────────────────────────────── -->
    <main id="main-content">
      <slot />
    </main>

    <!-- ─── Footer ─────────────────────────────────────────────────────────── -->
    <footer>
      <div class="container footer-inner">
        <p class="footer-copy">
          © {new Date().getFullYear()} {siteTitle}
          <span class="sep" aria-hidden="true">·</span>
          Built with <a href="https://astro.build" target="_blank" rel="noopener">{SITE.builtWith}</a>
        </p>
        <ul class="footer-links" role="list">
          {SITE.social.github && <li><a href={SITE.social.github} target="_blank" rel="noopener" aria-label="GitHub">GitHub</a></li>}
          {SITE.social.linkedin && <li><a href={SITE.social.linkedin} target="_blank" rel="noopener" aria-label="LinkedIn">LinkedIn</a></li>}
          <li><a href="/rss.xml" aria-label="RSS feed">RSS</a></li>
        </ul>
      </div>
    </footer>

    <!-- ─── Theme toggle script ─────────────────────────────────────────────── -->
    <script>
      const btn = document.getElementById("theme-toggle");
      btn?.addEventListener("click", () => {
        const html = document.documentElement;
        const next = html.getAttribute("data-theme") === "dark" ? "light" : "dark";
        html.setAttribute("data-theme", next);
        localStorage.setItem("theme", next);
      });

      // Shrink nav on scroll
      const header = document.getElementById("site-header");
      const observer = new IntersectionObserver(
        ([e]) => header?.classList.toggle("scrolled", !e.isIntersecting),
        { rootMargin: "-1px 0px 0px 0px", threshold: [1] }
      );
      const sentinel = document.createElement("div");
      sentinel.style.cssText = "height:1px;position:absolute;top:0;width:100%;pointer-events:none";
      document.body.prepend(sentinel);
      observer.observe(sentinel);
    </script>
  </body>
</html>

<style>
  /* ─── Header ─────────────────────────────────────────────────────────────── */
  #site-header {
    position: sticky;
    top: 0;
    z-index: 50;
    background: transparent;
    transition: background var(--duration) var(--ease-out),
                box-shadow var(--duration) var(--ease-out);
  }
  #site-header.scrolled {
    background: color-mix(in srgb, var(--bg) 85%, transparent);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    box-shadow: 0 1px 0 var(--border);
  }

  .nav-inner {
    display: flex;
    align-items: center;
    gap: var(--space-6);
    height: 64px;
  }

  .nav-logo { flex-shrink: 0; }
  .logo-mark {
    display: grid;
    place-items: center;
    width: 36px;
    height: 36px;
    border: 1.5px solid var(--border);
    border-radius: var(--radius-sm);
    font-family: var(--font-mono);
    font-size: 0.75rem;
    font-weight: 500;
    color: var(--text-muted);
    transition: border-color var(--duration), color var(--duration);
  }
  .nav-logo:hover .logo-mark {
    border-color: var(--accent);
    color: var(--accent);
  }

  .nav-links {
    display: flex;
    align-items: center;
    gap: var(--space-8);
    list-style: none;
    margin-left: auto;
  }
  .nav-links a {
    font-size: 0.875rem;
    color: var(--text-muted);
    transition: color var(--duration);
    letter-spacing: 0.01em;
  }
  .nav-links a:hover { color: var(--text); }

  .nav-actions {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    margin-left: var(--space-4);
  }

  /* Theme toggle */
  #theme-toggle {
    display: grid;
    place-items: center;
    width: 36px;
    height: 36px;
    border-radius: var(--radius-sm);
    color: var(--text-muted);
    transition: color var(--duration), background var(--duration);
  }
  #theme-toggle:hover {
    color: var(--text);
    background: var(--bg-card);
  }
  /* Show correct icon per theme */
  :root[data-theme="dark"]  #theme-toggle .icon-moon { display: none; }
  :root[data-theme="light"] #theme-toggle .icon-sun  { display: none; }

  /* Résumé button */
  .btn-resume {
    font-size: 0.8125rem;
    font-weight: 500;
    padding: 0.4em 1em;
    border: 1.5px solid var(--border);
    border-radius: var(--radius-sm);
    color: var(--text-muted);
    transition: border-color var(--duration), color var(--duration),
                background var(--duration);
    white-space: nowrap;
  }
  .btn-resume:hover {
    border-color: var(--accent);
    color: var(--accent);
    background: var(--accent-muted);
  }

  /* ─── Footer ─────────────────────────────────────────────────────────────── */
  footer {
    border-top: 1px solid var(--border);
    margin-top: var(--space-24);
  }
  .footer-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding-block: var(--space-8);
    flex-wrap: wrap;
    gap: var(--space-4);
  }
  .footer-copy {
    font-size: 0.8125rem;
    color: var(--text-muted);
  }
  .footer-copy a {
    color: var(--text-muted);
    text-underline-offset: 3px;
    text-decoration: underline;
    text-decoration-color: var(--border);
    transition: color var(--duration);
  }
  .footer-copy a:hover { color: var(--text); }
  .sep { margin-inline: var(--space-2); }
  .footer-links {
    display: flex;
    gap: var(--space-6);
    list-style: none;
  }
  .footer-links a {
    font-size: 0.8125rem;
    color: var(--text-muted);
    transition: color var(--duration);
  }
  .footer-links a:hover { color: var(--text); }

  /* ─── Responsive ─────────────────────────────────────────────────────────── */
  @media (max-width: 640px) {
    .nav-links { display: none; } /* Add a hamburger menu component later */
    .btn-resume { display: none; }
  }
</style>
