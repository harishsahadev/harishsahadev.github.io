---
import { getCollection, render } from "astro:content";
import ProjectPage from "../../layouts/ProjectPage.astro";
import { SITE } from "../../config/site";

export async function getStaticPaths() {
  const projects = await getCollection("projects");
  return projects.map((project) => ({
    params: { slug: project.id },
    props: { project },
  }));
}

const { project } = Astro.props;
const { Content } = await render(project);

function resolveProjectRepoUrl(repoUrl?: string) {
  if (!repoUrl) return undefined;

  return repoUrl.replace("https://github.com/yourusername/", `https://github.com/${SITE.social.githubUsername}/`);
}
---

<ProjectPage
  title={project.data.title}
  description={project.data.description}
  date={project.data.date}
  tech={project.data.tech}
  liveUrl={project.data.liveUrl}
  repoUrl={resolveProjectRepoUrl(project.data.repoUrl)}
  learnings={project.data.learnings}
  image={project.data.image}
  imageAlt={project.data.imageAlt}
  youtubeUrl={project.data.youtubeUrl}
>
  <Content />
</ProjectPage>
