---
interface Props {
  title: string;
  description: string;
  tech: string[];
  liveUrl?: string;
  repoUrl?: string;
  learnings?: string;
  slug?: string;
  showKnowMore?: boolean;
}

const { title, description, tech, liveUrl, repoUrl, learnings, slug, showKnowMore = false } = Astro.props;
---

<article class="project-card">
  <!-- Header — always visible, never animates away -->
  <header class="card-header">
    <h3 class="card-title">{title}</h3>
    <div class="card-actions">
      {repoUrl && (
        <a href={repoUrl} target="_blank" rel="noopener noreferrer" aria-label={`${title} source code`} class="icon-link">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0 1 12 6.844a9.59 9.59 0 0 1 2.504.337c1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.02 10.02 0 0 0 22 12.017C22 6.484 17.522 2 12 2z"/>
          </svg>
        </a>
      )}
      {liveUrl && (
        <a href={liveUrl} target="_blank" rel="noopener noreferrer" aria-label={`${title} live demo`} class="icon-link">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" x2="21" y1="14" y2="3"/>
          </svg>
        </a>
      )}
    </div>
  </header>

  <!-- Body crossfade zone -->
  <div class="card-body">
    <div class="card-default">
      <p class="card-desc">{description}</p>
      <ul class="tech-pills" role="list" aria-label="Technologies used">
        {tech.map((t) => <li class="pill">{t}</li>)}
      </ul>
    </div>

    {learnings && (
      <div class="card-learnings" aria-hidden="true">
        <p class="overlay-label">What I learned</p>
        <p class="overlay-text">{learnings}</p>
      </div>
    )}
  </div>

  {showKnowMore && slug && (
    <a href={`/projects/${slug}`} class="know-more-link">
      Know more
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="M5 12h14M12 5l7 7-7 7"/>
      </svg>
    </a>
  )}
</article>

<style>
  .project-card {
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    padding: var(--space-6);
    overflow: hidden;
    display: flex;
    flex-direction: column;
    gap: var(--space-5);
    transition: border-color var(--duration) var(--ease-out),
                transform 300ms var(--ease-out);
  }
  .project-card:hover {
    border-color: var(--accent);
    transform: translateY(-2px);
  }

  /* ── Header ── always visible ─────────────────────────────────────────────── */
  .card-header {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: var(--space-4);
    /* Ensure clicks on links always work regardless of body state */
    position: relative;
    z-index: 2;
  }
  .card-title {
    font-family: var(--font-serif);
    font-size: 1.125rem;
    line-height: 1.3;
    color: var(--text);
  }
  .card-actions {
    display: flex;
    gap: var(--space-2);
    flex-shrink: 0;
  }
  .icon-link {
    display: grid;
    place-items: center;
    width: 32px;
    height: 32px;
    border-radius: var(--radius-sm);
    color: var(--text-muted);
    border: 1px solid transparent;
    transition: color var(--duration), border-color var(--duration),
                background var(--duration);
  }
  .icon-link:hover {
    color: var(--text);
    border-color: var(--border);
    background: var(--bg-raised);
  }

  /* ── Body crossfade ───────────────────────────────────────────────────────── */
  .card-body {
    position: relative;
    min-height: 7rem;
    flex: 1;
  }

  .card-default,
  .card-learnings {
    transition: opacity 220ms var(--ease-out), transform 220ms var(--ease-out);
  }

  .card-learnings {
    position: absolute;
    inset: 0;
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: var(--space-3);
    opacity: 0;
    transform: translateY(6px);
    pointer-events: none;
  }

  .project-card:hover .card-default {
    opacity: 0;
    transform: translateY(-4px);
    pointer-events: none;
  }
  .project-card:hover .card-learnings {
    opacity: 1;
    transform: translateY(0);
    pointer-events: auto;
  }

  /* ── Default content ─────────────────────────────────────────────────────── */
  .card-desc {
    font-size: 0.875rem;
    color: var(--text-muted);
    line-height: 1.6;
    margin-bottom: var(--space-4);
  }
  .tech-pills {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
    list-style: none;
  }
  .pill {
    font-family: var(--font-mono);
    font-size: 0.6875rem;
    font-weight: 500;
    color: var(--text-muted);
    background: var(--bg-raised);
    border: 1px solid var(--border);
    border-radius: var(--radius-sm);
    padding: 0.2em 0.6em;
    letter-spacing: 0.02em;
    text-transform: uppercase;
  }

  /* ── Learnings content ───────────────────────────────────────────────────── */
  .overlay-label {
    font-family: var(--font-mono);
    font-size: 0.6875rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--accent);
  }
  .overlay-text {
    font-size: 0.9375rem;
    color: var(--text);
    line-height: 1.65;
  }

  .know-more-link {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    width: fit-content;
    margin-top: auto;
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--accent);
  }

  .know-more-link svg {
    transition: transform var(--duration) var(--ease-out);
  }

  .know-more-link:hover svg {
    transform: translateX(2px);
  }
</style>
