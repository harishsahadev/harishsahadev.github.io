---
import type { ContentDate } from "../utils/contentDates";
import { formatContentDate, getContentDateTime } from "../utils/contentDates";

interface Props {
  name: string;
  issuer: string;
  date: ContentDate;
  tags?: string[];
  verifyUrl?: string;
  badge?: string;
  description?: string;
  detailedDescription?: string;
}

const { name, issuer, date, tags = [], verifyUrl, badge, description, detailedDescription } = Astro.props;

const formattedDate = formatContentDate(date);
const dateTime = getContentDateTime(date);

const dialogId = `cert-dialog-${name.toLowerCase().replace(/[^a-z0-9]+/g, "-").replace(/(^-|-$)/g, "")}`;
const fullDescription = detailedDescription ?? description;
---

<article
  class="cert-card cert-trigger"
  role="button"
  tabindex="0"
  aria-haspopup="dialog"
  aria-controls={dialogId}
  data-dialog-id={dialogId}
>
  {badge && (
    <div class="cert-badge-wrap">
      <img src={badge} alt={`${name} badge`} class="cert-badge" width="64" height="64" loading="lazy" />
    </div>
  )}

  <div class="cert-body">
    <p class="cert-issuer">{issuer}</p>
    <h3 class="cert-name">{name}</h3>
    {description && <p class="cert-desc">{description}</p>}

    <div class="cert-meta">
      <time class="cert-date" datetime={dateTime}>
        {formattedDate}
      </time>

      {verifyUrl && (
        <a href={verifyUrl} target="_blank" rel="noopener noreferrer" class="cert-verify" data-cert-link>
          Verify
          <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <polyline points="20 6 9 17 4 12"/>
          </svg>
        </a>
      )}
    </div>
  </div>
</article>

<dialog class="cert-dialog" id={dialogId} aria-labelledby={`${dialogId}-title`}>
  <div class="cert-dialog-panel">
    <button type="button" class="cert-dialog-close" aria-label="Close certificate details" data-cert-close>
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="M18 6 6 18M6 6l12 12"/>
      </svg>
    </button>

    <div class="cert-dialog-body">
      <div class="cert-dialog-copy">
        <p class="cert-issuer">{issuer}</p>
        <h3 id={`${dialogId}-title`} class="cert-dialog-title">{name}</h3>

        {badge && (
          <figure class="cert-dialog-media">
            <img src={badge} alt={`${name} certificate preview`} loading="lazy" />
          </figure>
        )}

        {fullDescription && <p class="cert-dialog-desc">{fullDescription}</p>}

        {tags.length > 0 && (
          <ul class="cert-dialog-tags" role="list" aria-label="Certification topics">
            {tags.map((tag) => (
              <li class="cert-dialog-tag">{tag}</li>
            ))}
          </ul>
        )}

        <div class="cert-dialog-meta">
          <time class="cert-date" datetime={dateTime}>
            {formattedDate}
          </time>

          {verifyUrl && (
            <a href={verifyUrl} target="_blank" rel="noopener noreferrer" class="cert-verify">
              Verify
              <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <polyline points="20 6 9 17 4 12"/>
              </svg>
            </a>
          )}
        </div>
      </div>
    </div>
  </div>
</dialog>

<script is:inline>
  if (!window.__certDialogInit) {
    window.__certDialogInit = true;

    const openDialog = (dialog) => {
      if (!(dialog instanceof HTMLDialogElement)) return;
      dialog.showModal();
      document.body.classList.add("dialog-open");
    };

    const closeDialog = (dialog) => {
      if (!(dialog instanceof HTMLDialogElement)) return;
      dialog.close();
      if (!document.querySelector("dialog[open]")) {
        document.body.classList.remove("dialog-open");
      }
    };

    document.addEventListener("click", (event) => {
      const target = event.target;
      if (!(target instanceof Element)) return;

      if (target instanceof HTMLDialogElement && target.classList.contains("cert-dialog")) {
        closeDialog(target);
        return;
      }

      const closeButton = target.closest("[data-cert-close]");
      if (closeButton) {
        closeDialog(closeButton.closest("dialog"));
        return;
      }

      const trigger = target.closest(".cert-trigger");
      if (!trigger) return;

      if (target.closest("[data-cert-link]")) return;

      const dialogId = trigger.getAttribute("data-dialog-id");
      const dialog = dialogId ? document.getElementById(dialogId) : null;
      openDialog(dialog);
    });

    document.addEventListener("keydown", (event) => {
      const target = event.target;
      if (!(target instanceof Element)) return;

      const trigger = target.closest(".cert-trigger");
      if (!trigger) return;

      if (event.key !== "Enter" && event.key !== " ") return;

      event.preventDefault();
      const dialogId = trigger.getAttribute("data-dialog-id");
      const dialog = dialogId ? document.getElementById(dialogId) : null;
      openDialog(dialog);
    });

    document.addEventListener("close", () => {
      if (!document.querySelector("dialog[open]")) {
        document.body.classList.remove("dialog-open");
      }
    }, true);
  }
</script>

<style>
  .cert-card {
    display: flex;
    align-items: center;
    gap: var(--space-4);
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    padding: var(--space-6);
    transition: border-color var(--duration) var(--ease-out),
                transform 300ms var(--ease-out);
    cursor: pointer;
  }
  .cert-card:hover {
    border-color: color-mix(in srgb, var(--accent) 60%, transparent);
    transform: translateY(-1px);
  }

  .cert-badge-wrap {
    flex-shrink: 0;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .cert-badge {
    width: 52px;
    height: 52px;
    object-fit: contain;
    border-radius: var(--radius-sm);
  }

  .cert-body {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
    min-width: 0;
    flex: 1;
  }

  .cert-issuer {
    font-family: var(--font-mono);
    font-size: 0.6875rem;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--accent);
  }

  .cert-name {
    font-size: 0.9375rem;
    font-weight: 600;
    color: var(--text);
    line-height: 1.3;
    margin-top: var(--space-1);
    /* Truncate long names gracefully */
    overflow: hidden;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
  }

  .cert-desc {
    font-size: 0.8125rem;
    color: var(--text-muted);
    line-height: 1.5;
    display: -webkit-box;
    overflow: hidden;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
  }

  .cert-meta {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-3);
    margin-top: auto;
    padding-top: var(--space-4);
  }

  .cert-date {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--text-faint);
  }

  .cert-verify {
    display: inline-flex;
    align-items: center;
    gap: var(--space-1);
    font-size: 0.75rem;
    font-weight: 500;
    color: var(--text-muted);
    border: 1px solid var(--border);
    border-radius: 999px;
    padding: 0.3em 0.8em;
    transition: color var(--duration), border-color var(--duration),
                background var(--duration);
  }
  .cert-verify:hover {
    color: var(--accent);
    border-color: var(--accent);
    background: var(--accent-muted);
  }

  .cert-dialog {
    width: min(30rem, calc(100vw - 2rem));
    max-height: calc(100vh - 4rem);
    margin: auto;
    padding: 0;
    border: none;
    background: transparent;
    color: inherit;
  }

  .cert-dialog::backdrop {
    background: rgba(9, 9, 9, 0.76);
    backdrop-filter: blur(8px);
  }

  .cert-dialog-panel {
    position: relative;
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    overflow: hidden;
    box-shadow: 0 24px 80px rgba(0, 0, 0, 0.38);
  }

  .cert-dialog-close {
    position: absolute;
    top: var(--space-4);
    right: var(--space-4);
    display: grid;
    place-items: center;
    width: 2.25rem;
    height: 2.25rem;
    border-radius: 999px;
    color: var(--text-muted);
    background: color-mix(in srgb, var(--bg) 88%, transparent);
    border: 1px solid var(--border);
    z-index: 2;
  }

  .cert-dialog-close:hover {
    color: var(--text);
    background: var(--bg-raised);
  }

  .cert-dialog-body {
    padding: var(--space-8);
  }

  .cert-dialog-copy {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
    min-width: 0;
  }

  .cert-dialog-title {
    font-family: var(--font-serif);
    font-size: clamp(1.35rem, 3vw, 1.9rem);
    line-height: 1.2;
  }

  .cert-dialog-media {
    background:
      radial-gradient(circle at top left, var(--accent-muted), transparent 40%),
      var(--bg-raised);
    border: 1px solid var(--border);
    border-radius: var(--radius-md);
    padding: var(--space-4);
    margin-top: var(--space-1);
  }

  .cert-dialog-media img {
    width: 100%;
    max-height: 14rem;
    object-fit: contain;
    margin-inline: auto;
  }

  .cert-dialog-desc {
    font-size: 0.9rem;
    color: var(--text-muted);
    line-height: 1.7;
  }

  .cert-dialog-tags {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
    list-style: none;
  }

  .cert-dialog-tag {
    font-family: var(--font-mono);
    font-size: 0.6875rem;
    font-weight: 500;
    color: var(--text-muted);
    background: var(--bg-raised);
    border: 1px solid var(--border);
    border-radius: 999px;
    padding: 0.3rem 0.65rem;
    letter-spacing: 0.04em;
    text-transform: uppercase;
  }

  .cert-dialog-meta {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-3);
    flex-wrap: wrap;
    margin-top: var(--space-2);
    padding-top: var(--space-4);
    border-top: 1px solid var(--border);
  }

  @media (max-width: 760px) {
    .cert-dialog-body {
      padding: var(--space-6);
    }
  }
</style>
