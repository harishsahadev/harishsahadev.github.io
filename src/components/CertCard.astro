---
interface Props {
  name: string;
  issuer: string;
  date: Date;
  verifyUrl?: string;
  badge?: string;
  description?: string;
}

const { name, issuer, date, verifyUrl, badge, description } = Astro.props;

const formattedDate = date.toLocaleDateString("en-US", {
  month: "short",
  year: "numeric",
});
---

<article class="cert-card">
  {badge && (
    <div class="cert-badge-wrap">
      <img src={badge} alt={`${name} badge`} class="cert-badge" width="64" height="64" loading="lazy" />
    </div>
  )}

  <div class="cert-body">
    <p class="cert-issuer">{issuer}</p>
    <h3 class="cert-name">{name}</h3>
    {description && <p class="cert-desc">{description}</p>}

    <div class="cert-meta">
      <time class="cert-date" datetime={date.toISOString()}>
        {formattedDate}
      </time>

      {verifyUrl && (
        <a href={verifyUrl} target="_blank" rel="noopener noreferrer" class="cert-verify">
          Verify
          <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <polyline points="20 6 9 17 4 12"/>
          </svg>
        </a>
      )}
    </div>
  </div>
</article>

<style>
  .cert-card {
    display: flex;
    gap: var(--space-4);
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    padding: var(--space-5);
    transition: border-color var(--duration) var(--ease-out),
                transform 300ms var(--ease-out);
  }
  .cert-card:hover {
    border-color: color-mix(in srgb, var(--accent) 60%, transparent);
    transform: translateY(-1px);
  }

  .cert-badge-wrap {
    flex-shrink: 0;
  }
  .cert-badge {
    width: 52px;
    height: 52px;
    object-fit: contain;
    border-radius: var(--radius-sm);
  }

  .cert-body {
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
    min-width: 0;
  }

  .cert-issuer {
    font-family: var(--font-mono);
    font-size: 0.6875rem;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--accent);
  }

  .cert-name {
    font-size: 0.9375rem;
    font-weight: 600;
    color: var(--text);
    line-height: 1.3;
    /* Truncate long names gracefully */
    overflow: hidden;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
  }

  .cert-desc {
    font-size: 0.8125rem;
    color: var(--text-muted);
    line-height: 1.5;
    margin-top: var(--space-1);
  }

  .cert-meta {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-top: var(--space-3);
  }

  .cert-date {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--text-faint);
  }

  .cert-verify {
    display: inline-flex;
    align-items: center;
    gap: var(--space-1);
    font-size: 0.75rem;
    font-weight: 500;
    color: var(--text-muted);
    border: 1px solid var(--border);
    border-radius: 999px;
    padding: 0.2em 0.75em;
    transition: color var(--duration), border-color var(--duration),
                background var(--duration);
  }
  .cert-verify:hover {
    color: var(--accent);
    border-color: var(--accent);
    background: var(--accent-muted);
  }
</style>
